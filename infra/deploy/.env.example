# AIASys 部署配置模板
# ================================
# 推荐做法：
# 1. 复制本文件为 infra/deploy/.env
# 2. 在 .env 中直接维护测试 / 发布两套目标
# 3. 通过 DEPLOY_TARGET=test|prod 选择当前要部署的目标
# ================================

# --------------------------------
# 部署目标选择
# --------------------------------

# 默认先部署到测试环境；发布环境请显式使用 DEPLOY_TARGET=prod
DEPLOY_TARGET=test

# --------------------------------
# 通用默认值（可被 TEST_/PROD_ 覆盖）
# --------------------------------

# 服务器上项目存放路径
REMOTE_DIR=/opt/aiasys

# 对外服务端口
REMOTE_FRONTEND_PORT=13000
REMOTE_BACKEND_PORT=13001

# 部署时写入前端构建产物的 API 地址
# 推荐按目标分别配置 TEST_/PROD_REMOTE_PUBLIC_API_BASE_URL
# REMOTE_PUBLIC_API_BASE_URL=http://your_server_ip:13001

# 是否本地预构建前端（低配服务器建议保持 1）
DEPLOY_BUILD_FRONTEND_LOCALLY=1

# 可选：远端鉴权模式
DEPLOY_AUTH_MODE=local

# 云端部署默认强制使用 Docker 沙盒，并禁用本地沙盒选项
DEPLOY_SANDBOX_MODE=docker
DEPLOY_SANDBOX_ALLOW_LOCAL=false

# --------------------------------
# 单目标 / 兼容模式（可选）
# --------------------------------

# 如果你只维护一台服务器，可以直接填写以下变量
# SERVER_IP=your_server_ip
# SERVER_PORT=22
# SERVER_USER=root
# SERVER_PASS=your_password
# SSH_KEY_PATH=~/.ssh/id_rsa

# --------------------------------
# 测试环境（DEPLOY_TARGET=test）
# --------------------------------

TEST_SERVER_IP=your_test_server_ip
TEST_SERVER_PORT=22
TEST_SERVER_USER=root
TEST_SERVER_PASS=your_test_password
TEST_REMOTE_DIR=/opt/aiasys
TEST_REMOTE_FRONTEND_PORT=13000
TEST_REMOTE_BACKEND_PORT=13001
TEST_REMOTE_PUBLIC_API_BASE_URL=http://your_test_server_ip:13001
# TEST_SSH_KEY_PATH=~/.ssh/id_rsa

# --------------------------------
# 发布环境（DEPLOY_TARGET=prod）
# --------------------------------

PROD_SERVER_IP=your_prod_server_ip
PROD_SERVER_PORT=22
PROD_SERVER_USER=root
PROD_SERVER_PASS=your_prod_password
PROD_REMOTE_DIR=/opt/aiasys
PROD_REMOTE_FRONTEND_PORT=13000
PROD_REMOTE_BACKEND_PORT=13001
PROD_REMOTE_PUBLIC_API_BASE_URL=http://your_prod_server_ip:13001
# PROD_SSH_KEY_PATH=~/.ssh/id_rsa

# --------------------------------
# 可选：数据库 / 沙盒覆盖
# --------------------------------

# TEST_REMOTE_DB_HOST=127.0.0.1
# TEST_REMOTE_DB_PORT=5433
# TEST_REMOTE_SANDBOX_DB_HOST=127.0.0.1
# TEST_REMOTE_SANDBOX_DB_PORT=5434
# TEST_DEPLOY_SANDBOX_MODE=docker
# TEST_DEPLOY_SANDBOX_ALLOW_LOCAL=false
# PROD_REMOTE_DB_HOST=127.0.0.1
# PROD_REMOTE_DB_PORT=5433
# PROD_REMOTE_SANDBOX_DB_HOST=127.0.0.1
# PROD_REMOTE_SANDBOX_DB_PORT=5434
# PROD_DEPLOY_SANDBOX_MODE=docker
# PROD_DEPLOY_SANDBOX_ALLOW_LOCAL=false
# REMOTE_DB_HOST=127.0.0.1
# REMOTE_DB_PORT=5433
# REMOTE_SANDBOX_DB_HOST=127.0.0.1
# REMOTE_SANDBOX_DB_PORT=5434
# DEPLOY_JWT_SECRET=replace_with_real_secret
